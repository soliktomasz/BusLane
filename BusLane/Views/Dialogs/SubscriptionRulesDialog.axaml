<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BusLane.ViewModels"
             x:Class="BusLane.Views.Dialogs.SubscriptionRulesDialog"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">

    <Border Classes="modal-overlay"
            IsVisible="{Binding EntityOperations.ShowSubscriptionRulesDialog}">
        <Border Background="{DynamicResource CardBackground}"
                CornerRadius="14"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderDefault}"
                BoxShadow="0 12 32 0 #38000000"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                MinWidth="680"
                MaxWidth="840"
                MaxHeight="720"
                ClipToBounds="True"
                Padding="0">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Background="{DynamicResource SurfaceSubtle}"
                        CornerRadius="14,14,0,0"
                        Padding="20,16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0"
                                Width="36" Height="36"
                                CornerRadius="8"
                                Background="{DynamicResource SurfaceInfo}"
                                Margin="0,0,12,0">
                            <LucideIcon Kind="ListFilter" Size="18"
                                        Foreground="{DynamicResource TextInfo}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Subscription Rules"
                                       Classes="heading"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding EntityOperations.RulesSubscription.TopicName}"
                                           FontSize="12"
                                           FontFamily="Cascadia Code, Consolas, Monaco, monospace"
                                           Foreground="{DynamicResource SubtleForeground}"/>
                                <TextBlock Text="/"
                                           FontSize="12"
                                           Foreground="{DynamicResource SubtleForeground}"/>
                                <TextBlock Text="{Binding EntityOperations.RulesSubscription.Name}"
                                           FontSize="12"
                                           FontFamily="Cascadia Code, Consolas, Monaco, monospace"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrand}"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="2" Classes="icon"
                                Command="{Binding EntityOperations.CloseSubscriptionRulesDialogCommand}"
                                ToolTip.Tip="Close">
                            <LucideIcon Kind="X" Size="16"/>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="18" Margin="20,20,20,28">
                        <StackPanel Spacing="8">
                            <TextBlock Text="RULES" Classes="field-group-header"/>
                            <Border Classes="surface-subtle" Padding="12">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Loading rules..."
                                               Classes="caption"
                                               IsVisible="{Binding EntityOperations.IsLoadingSubscriptionRules}"/>
                                    <ItemsControl ItemsSource="{Binding EntityOperations.SubscriptionRules}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource BorderDefault}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,8">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <StackPanel Grid.Column="0" Spacing="4">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontWeight="SemiBold"
                                                                           FontFamily="Cascadia Code, Consolas, Monaco, monospace"/>
                                                                <TextBlock Text="{Binding FilterType}"
                                                                           Classes="caption"/>
                                                            </StackPanel>
                                                            <SelectableTextBlock Text="{Binding DisplayExpression}"
                                                                                 TextWrapping="Wrap"
                                                                                 FontFamily="Cascadia Code, Consolas, Monaco, monospace"
                                                                                 FontSize="12"/>
                                                            <SelectableTextBlock Text="{Binding ActionExpression}"
                                                                                 TextWrapping="Wrap"
                                                                                 FontFamily="Cascadia Code, Consolas, Monaco, monospace"
                                                                                 FontSize="12"
                                                                                 IsVisible="{Binding ActionExpression, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Classes="icon danger"
                                                                Command="{Binding $parent[Window].DataContext.EntityOperations.DeleteSubscriptionRuleRequestCommand}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip.Tip="Delete rule">
                                                            <LucideIcon Kind="Trash2" Size="15"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No rules"
                                               Classes="caption"
                                               IsVisible="{Binding !EntityOperations.SubscriptionRules.Count}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="ADD SQL FILTER" Classes="field-group-header"/>
                            <Border Classes="surface-subtle" Padding="14">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                                    <TextBox Grid.Row="0"
                                             PlaceholderText="Rule name"
                                             Text="{Binding EntityOperations.NewRuleName}"/>
                                    <TextBox Grid.Row="1"
                                             PlaceholderText="SQL expression"
                                             AcceptsReturn="True"
                                             MinHeight="72"
                                             Text="{Binding EntityOperations.NewRuleSqlExpression}"/>
                                    <TextBox Grid.Row="2"
                                             PlaceholderText="Optional SQL action"
                                             Text="{Binding EntityOperations.NewRuleActionExpression}"/>
                                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding EntityOperations.SubscriptionRuleValidationMessage}"
                                                   Foreground="{DynamicResource TextDanger}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding EntityOperations.SubscriptionRuleValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <Button Grid.Column="1"
                                                Classes="primary"
                                                Command="{Binding EntityOperations.CreateSubscriptionRuleCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <LucideIcon Kind="Plus" Size="15"/>
                                                <TextBlock Text="Add Rule"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="CORRELATION FILTERS" Classes="field-group-header"/>
                            <Border Classes="surface-subtle" Padding="14">
                                <TextBlock Text="Correlation filters can be viewed and deleted here. Creating correlation filters with key/value editing will be added in a later pass."
                                           Classes="caption"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Border>
</UserControl>
