<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BusLane.ViewModels"
             xmlns:core="using:BusLane.ViewModels.Core"
             x:Class="BusLane.Views.Dialogs.CommandPaletteDialog"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">

    <Border Classes="modal-overlay"
            IsVisible="{Binding CommandPalette.IsOpen}">
        <Border Classes="modal modal-medium"
                Width="720"
                MaxHeight="620"
                Padding="0"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,72,0,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0"
                        Classes="dialog-header">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                Width="36"
                                Height="36"
                                CornerRadius="8"
                                Background="{DynamicResource SurfaceBrand}">
                            <LucideIcon Kind="Search"
                                        Size="18"
                                        Foreground="{DynamicResource AccentBrand}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                        </Border>

                        <TextBox Grid.Column="1"
                                 x:Name="CommandPaletteSearchTextBox"
                                 Text="{Binding CommandPalette.SearchText, Mode=TwoWay}"
                                 PlaceholderText="Search commands, connections, queues, topics..."
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="16"
                                 VerticalAlignment="Center"
                                 Padding="0,6"/>

                        <Button Grid.Column="2"
                                Classes="icon"
                                Command="{Binding CloseCommandPaletteCommand}"
                                VerticalAlignment="Center">
                            <LucideIcon Kind="X" Size="16"/>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Classes="dialog-body"
                        Padding="12">
                    <ListBox ItemsSource="{Binding CommandPalette.FilteredItems}"
                             SelectedItem="{Binding CommandPalette.SelectedItem, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             MaxHeight="430"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="core:CommandPaletteItem">
                                <Button Classes="subtle"
                                        Command="{Binding $parent[Window].DataContext.ExecuteCommandPaletteItemCommand}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Padding="10"
                                        Margin="0,2">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Border Grid.Column="0"
                                                Width="34"
                                                Height="34"
                                                CornerRadius="8"
                                                Background="{DynamicResource SurfaceSubtle}">
                                            <LucideIcon Kind="{Binding Icon}"
                                                        Size="16"
                                                        Foreground="{DynamicResource AccentBrand}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    Spacing="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       Classes="body-strong"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Classes="caption"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Classes="badge-muted"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Category}"/>
                                        </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Border Grid.Row="2"
                        Classes="dialog-footer">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding KeyboardShortcuts.PrimaryModifierDisplay, StringFormat='{}{0}+K opens this palette'}"
                                   Classes="caption"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Classes="secondary small"
                                Command="{Binding ExecuteCommandPaletteItemCommand}"
                                CommandParameter="{Binding CommandPalette.SelectedItem}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <LucideIcon Kind="Check" Size="13"/>
                                <TextBlock Text="Run"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</UserControl>
