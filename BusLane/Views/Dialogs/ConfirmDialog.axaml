<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BusLane.ViewModels"
             x:Class="BusLane.Views.Dialogs.ConfirmDialog"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">
    
    <Border Classes="modal-overlay"
            IsVisible="{Binding Confirmation.ShowConfirmDialog}">
        <Border Classes="modal modal-small"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="0">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header -->
                <Border Grid.Row="0" Classes="dialog-header">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0"
                                Width="36" Height="36"
                                CornerRadius="8"
                                Background="{DynamicResource SurfaceDanger}"
                                Margin="0,0,12,0">
                            <LucideIcon Kind="TriangleAlert" Size="18"
                                        Foreground="{DynamicResource TextDanger}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Confirmation.ConfirmDialogTitle}"
                                   Classes="heading"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Classes="icon"
                                Command="{Binding Confirmation.CancelConfirmDialogCommand}">
                            <LucideIcon Kind="X" Size="16"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Message -->
                <Border Grid.Row="1" Classes="dialog-body">
                    <TextBlock Text="{Binding Confirmation.ConfirmDialogMessage}"
                               TextWrapping="Wrap"
                               Classes="body"/>
                </Border>

                <!-- Action Buttons -->
                <Border Grid.Row="2" Classes="dialog-footer">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Classes="secondary small"
                                Content="Cancel"
                                Command="{Binding Confirmation.CancelConfirmDialogCommand}"/>
                        <Button Classes="danger small"
                                Content="{Binding Confirmation.ConfirmDialogConfirmText}"
                                Command="{Binding Confirmation.ExecuteConfirmDialogCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</UserControl>

