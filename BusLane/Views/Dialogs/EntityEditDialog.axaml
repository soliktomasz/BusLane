<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BusLane.ViewModels"
             x:Class="BusLane.Views.Dialogs.EntityEditDialog"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">

    <Border Classes="modal-overlay"
            IsVisible="{Binding EntityOperations.ShowEntityEditDialog}">
        <Border Background="{DynamicResource CardBackground}"
                CornerRadius="14"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderDefault}"
                BoxShadow="0 12 32 0 #38000000"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                MinWidth="560"
                MaxWidth="720"
                ClipToBounds="True"
                Padding="0">
            <Grid RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0"
                        Background="{DynamicResource SurfaceSubtle}"
                        CornerRadius="14,14,0,0"
                        Padding="20,16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0"
                                Width="36" Height="36"
                                CornerRadius="8"
                                Background="{DynamicResource SurfaceWarning}"
                                Margin="0,0,12,0">
                            <LucideIcon Kind="Pencil" Size="18"
                                        Foreground="{DynamicResource TextWarning}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding EntityOperations.EntityEditTitle}"
                                   Classes="heading"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Classes="icon"
                                Command="{Binding EntityOperations.CloseEntityEditDialogCommand}"
                                ToolTip.Tip="Close">
                            <LucideIcon Kind="X" Size="16"/>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="14" Margin="20,20,20,16">
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding !EntityOperations.IsEditingTopic}">
                            <TextBlock Text="Lock Duration" Classes="caption"/>
                            <TextBox Text="{Binding EntityOperations.EditLockDuration}"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Default Message TTL" Classes="caption"/>
                            <TextBox Text="{Binding EntityOperations.EditDefaultMessageTimeToLive}"/>
                        </StackPanel>

                        <StackPanel Spacing="14"
                                    IsVisible="{Binding EntityOperations.IsEditingSubscription}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Max Delivery Count" Classes="caption"/>
                                <TextBox Text="{Binding EntityOperations.EditMaxDeliveryCount}"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Auto Delete on Idle" Classes="caption"/>
                                <TextBox Text="{Binding EntityOperations.EditAutoDeleteOnIdle}"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Forward To" Classes="caption"/>
                                <TextBox Text="{Binding EntityOperations.EditForwardTo}"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Forward DLQ To" Classes="caption"/>
                                <TextBox Text="{Binding EntityOperations.EditForwardDeadLetteredMessagesTo}"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{Binding EntityOperations.EntityEditValidationMessage}"
                                   Foreground="{DynamicResource TextDanger}"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding EntityOperations.EntityEditValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{DynamicResource SurfaceSubtle}"
                        Padding="16">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="10">
                        <Button Content="Cancel"
                                Command="{Binding EntityOperations.CloseEntityEditDialogCommand}"/>
                        <Button Classes="primary"
                                Command="{Binding EntityOperations.SaveEntityEditCommand}"
                                IsEnabled="{Binding !EntityOperations.IsUpdatingEntity}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <LucideIcon Kind="Save" Size="15"/>
                                <TextBlock Text="Save"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</UserControl>
