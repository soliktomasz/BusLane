<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BusLane.ViewModels.Dashboard;assembly=BusLane"
             xmlns:controls="clr-namespace:BusLane.Views.Controls;assembly=BusLane"
             mc:Ignorable="d"
             x:Class="BusLane.Views.Controls.NamespaceDashboardView"
             x:DataType="vm:NamespaceDashboardViewModel"
             x:CompileBindings="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
              Margin="24">

            <!-- Header -->
            <Border Grid.Row="0"
                    Classes="page-header-surface"
                    Margin="0,0,0,20">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Classes="metric-icon-surface" Margin="0,0,12,0">
                        <LucideIcon Kind="LayoutDashboard" Size="16"
                                    Foreground="{DynamicResource AccentBrand}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Spacing="4"
                                VerticalAlignment="Center">
                        <TextBlock Text="Namespace Overview"
                                   Classes="heading"/>
                        <TextBlock Text="Use the inbox first, then skim the summary and supporting trends."
                                   Classes="caption"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ToggleSwitch IsChecked="{Binding AutoRefreshEnabled}"
                                         OnContent="Auto"
                                         OffContent="Auto"/>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="4"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding AutoRefreshEnabled}">
                                <ComboBox ItemsSource="{Binding RefreshIntervalOptions}"
                                          SelectedItem="{Binding RefreshIntervalSeconds}"
                                          Width="78"/>
                                <TextBlock Text="sec"
                                           Classes="caption"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Classes="secondary small"
                                Command="{Binding RefreshCommand}"
                                IsEnabled="{Binding !IsRefreshing}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <LucideIcon Kind="RefreshCw" Size="14"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Priority Inbox -->
            <controls:NamespaceInboxView Grid.Row="1"
                                         DataContext="{Binding Inbox}"
                                         Margin="0,0,0,20"/>

            <!-- Metric Cards Row -->
            <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*" ColumnSpacing="10" Margin="0,0,0,20">
                <Border Grid.Column="0" Classes="dashboard-summary-surface">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="metric-icon-surface">
                                <LucideIcon Kind="Inbox" Size="18" Foreground="{DynamicResource AccentBrand}"/>
                            </Border>
                            <TextBlock Text="Active Messages"
                                       Classes="caption"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <controls:MetricCard DataContext="{Binding ActiveMessagesCard}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="dashboard-summary-surface">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="metric-icon-surface">
                                <LucideIcon Kind="TriangleAlert" Size="18" Foreground="{DynamicResource TextDanger}"/>
                            </Border>
                            <TextBlock Text="Dead Letters"
                                       Classes="caption"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <controls:MetricCard DataContext="{Binding DeadLetterCard}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="dashboard-summary-surface">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="metric-icon-surface">
                                <LucideIcon Kind="Clock" Size="18" Foreground="{DynamicResource TextWarning}"/>
                            </Border>
                            <TextBlock Text="Scheduled"
                                       Classes="caption"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <controls:MetricCard DataContext="{Binding ScheduledCard}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Classes="dashboard-summary-surface">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="metric-icon-surface">
                                <LucideIcon Kind="HardDrive" Size="18" Foreground="{DynamicResource TextSuccess}"/>
                            </Border>
                            <TextBlock Text="Total Size"
                                       Classes="caption"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <controls:MetricCard DataContext="{Binding SizeCard}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Top Entities Lists -->
            <Grid Grid.Row="3" ColumnDefinitions="*,*" Margin="0,0,0,20">
                <controls:TopEntitiesList Grid.Column="0"
                                          DataContext="{Binding TopQueues}"
                                          Margin="0,0,10,0"/>
                <controls:TopEntitiesList Grid.Column="1"
                                          DataContext="{Binding TopTopics}"
                                          Margin="10,0,0,0"/>
            </Grid>

            <!-- Charts Grid -->
            <ItemsControl Grid.Row="4"
                          ItemsSource="{Binding Charts}"
                          HorizontalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:DashboardChart DataContext="{Binding}"
                                                 HorizontalAlignment="Stretch"
                                                 Margin="0,0,12,12"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
