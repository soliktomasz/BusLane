<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BusLane.ViewModels.Dashboard;assembly=BusLane"
             mc:Ignorable="d"
             x:Class="BusLane.Views.Controls.NamespaceInboxView"
             x:DataType="vm:NamespaceInboxViewModel"
             x:CompileBindings="False">
    <Border Classes="dashboard-inbox-surface">
        <StackPanel Spacing="16">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Border Grid.Column="0" Classes="metric-icon-surface">
                    <LucideIcon Kind="Inbox" Size="16"
                                Foreground="{DynamicResource AccentBrand}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Priority Inbox"
                               Classes="heading"/>
                    <TextBlock Text="Queues and subscriptions ranked for daily triage."
                               Classes="caption"/>
                </StackPanel>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Items.Count, StringFormat={}Items {0}}"
                               Classes="caption"
                               VerticalAlignment="Center"/>
                    <Button Classes="subtle small"
                            Command="{Binding ToggleExpandedCommand}">
                        <TextBlock Text="{Binding ExpandButtonText}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <StackPanel Spacing="16"
                        IsVisible="{Binding IsExpanded}">
                <Border Classes="dialog-section-surface"
                        IsVisible="{Binding IsEmpty}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Nothing needs attention right now."
                                   Classes="title-small"/>
                        <TextBlock Text="The inbox will populate on the next namespace refresh when queues or subscriptions start changing."
                                   Classes="caption"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:NamespaceInboxItemViewModel">
                            <Border Classes="inbox-item-surface"
                                    Margin="0,0,0,12">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding EntityName}"
                                                           Classes="title-small"/>
                                                <Border Padding="8,2"
                                                        CornerRadius="999"
                                                        Background="{DynamicResource AccentBrandSubtle}">
                                                    <TextBlock Text="{Binding EntityType}"
                                                               FontSize="11"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ReasonSummary}"
                                                       Classes="caption"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    HorizontalAlignment="Right"
                                                    Spacing="4">
                                            <TextBlock Text="{Binding Score, StringFormat={}Priority {0:0}}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding ActiveAlertCount, StringFormat={}Alerts {0}}"
                                                       Classes="caption"
                                                       HorizontalAlignment="Right"
                                                       IsVisible="{Binding HasActiveAlerts}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*,*,*"
                                          ColumnSpacing="12">
                                        <Border Grid.Column="0"
                                                Classes="inbox-stat-block">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Active"
                                                           Classes="caption"/>
                                                <TextBlock Text="{Binding ActiveMessageCount}"/>
                                                <TextBlock Text="{Binding ActiveMessageDelta, StringFormat={}Δ {0}}"
                                                           Classes="caption"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Classes="inbox-stat-block">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="DLQ"
                                                           Classes="caption"/>
                                                <TextBlock Text="{Binding DeadLetterCount}"/>
                                                <TextBlock Text="{Binding DeadLetterDelta, StringFormat={}Δ {0}}"
                                                           Classes="caption"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2"
                                                Classes="inbox-stat-block">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Scheduled"
                                                           Classes="caption"/>
                                                <TextBlock Text="{Binding ScheduledCount}"/>
                                                <TextBlock Text="{Binding ScheduledDelta, StringFormat={}Δ {0}}"
                                                           Classes="caption"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="3"
                                                Classes="inbox-stat-block">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Alert Delta"
                                                           Classes="caption"/>
                                                <TextBlock Text="{Binding AlertDelta}"/>
                                                <TextBlock Text="Since review"
                                                           Classes="caption"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Classes="secondary small"
                                                Command="{Binding OpenMessagesCommand}">
                                            <TextBlock Text="Open Messages"/>
                                        </Button>
                                        <Button Classes="secondary small"
                                                Command="{Binding OpenDeadLetterCommand}">
                                            <TextBlock Text="Open DLQ"/>
                                        </Button>
                                        <Button Classes="secondary small"
                                                Command="{Binding OpenSessionInspectorCommand}"
                                                IsVisible="{Binding CanOpenSessionInspector}">
                                            <TextBlock Text="Open Sessions"/>
                                        </Button>
                                        <Button Classes="subtle small"
                                                Command="{Binding MarkReviewedCommand}">
                                            <TextBlock Text="Mark Reviewed"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
