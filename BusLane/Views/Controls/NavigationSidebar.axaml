<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BusLane.ViewModels"
             xmlns:models="using:BusLane.Models"
             xmlns:converters="using:BusLane.Converters"
             x:Class="BusLane.Views.Controls.NavigationSidebar"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="False">

    <UserControl.Resources>
        <converters:EntitySelectionConverter x:Key="EntitySelectionConverter"/>
        <converters:EntitySelectionBackgroundConverter x:Key="EntitySelectionBackgroundConverter"/>
    </UserControl.Resources>

    <Border Classes="sidebar">
        <Grid RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0" Classes="sidebar-header">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                        <Viewbox Width="28" Height="28">
                            <Canvas Width="512" Height="512">
                                <Rectangle Canvas.Left="0" Canvas.Top="0" Width="512" Height="512" RadiusX="108" RadiusY="108" Fill="#18181b"/>
                                <Rectangle Canvas.Left="96" Canvas.Top="152" Width="128" Height="56" RadiusX="28" RadiusY="28" Fill="#27272a"/>
                                <Rectangle Canvas.Left="248" Canvas.Top="152" Width="168" Height="56" RadiusX="28" RadiusY="28" Fill="#27272a"/>
                                <Rectangle Canvas.Left="96" Canvas.Top="228" Width="320" Height="56" RadiusX="28" RadiusY="28" Fill="#6366f1"/>
                                <Rectangle Canvas.Left="96" Canvas.Top="304" Width="200" Height="56" RadiusX="28" RadiusY="28" Fill="#27272a"/>
                                <Ellipse Canvas.Left="316" Canvas.Top="304" Width="56" Height="56" Fill="#27272a"/>
                            </Canvas>
                        </Viewbox>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="BusLane" Classes="heading"/>
                            <TextBlock Text="Control rail" Classes="caption" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Classes="panel-toggle"
                            Command="{Binding ToggleNavigationPanelCommand}"
                            ToolTip.Tip="Hide navigation panel"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="12,0,0,0"
                            Padding="6">
                        <LucideIcon Kind="PanelLeftClose" Size="18"/>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="12,16,12,16" Spacing="18">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Workspace" Classes="sidebar-section-label"/>

                        <Border Classes="sidebar-workspace-summary"
                                IsVisible="{Binding HasActiveConnectionTab}">
                            <StackPanel Spacing="10">
                                <Grid Classes="sidebar-workspace-header"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <StackPanel Grid.Column="0" Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Classes="badge-success">
                                                <TextBlock Text="Connected"/>
                                            </Border>
                                            <Border Classes="badge-info">
                                                <TextBlock Text="{Binding ActiveWorkspaceModeLabel}"/>
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Text="{Binding ActiveTab.TabTitle}"
                                                   Classes="heading"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Text="{Binding ActiveTab.TabSubtitle}"
                                                   Classes="caption"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   IsVisible="{Binding ActiveTab.TabSubtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Width="36"
                                            Height="36"
                                            CornerRadius="10"
                                            Background="{DynamicResource SurfaceBrand}"
                                            HorizontalAlignment="Right">
                                        <LucideIcon Kind="Waypoints"
                                                    Size="18"
                                                    Foreground="{DynamicResource AccentBrand}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <Border Classes="badge-danger"
                                        HorizontalAlignment="Left"
                                        IsVisible="{Binding CurrentNavigation.HasDeadLetters}">
                                    <TextBlock Text="{Binding CurrentNavigation.TotalDeadLetterCount, StringFormat='{}{0} dead letters'}"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>

                                <WrapPanel Classes="sidebar-workspace-meta"
                                           Orientation="Horizontal"
                                           ItemHeight="28"
                                           IsVisible="{Binding IsActiveTabConnectionStringMode}">
                                    <Border Classes="badge-env"
                                            Margin="0,0,6,6"
                                            IsVisible="{Binding ActiveTab.SavedConnection.HasEnvironment}">
                                        <TextBlock Text="{Binding ActiveTab.SavedConnection.EnvironmentDisplayName}"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </WrapPanel>

                                <StackPanel Classes="sidebar-workspace-actions"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                    <Button Classes="icon-button"
                                            Command="{Binding OpenNamespacePanelCommand}"
                                            ToolTip.Tip="Change namespace"
                                            IsVisible="{Binding IsActiveTabAzureMode}">
                                        <LucideIcon Kind="ArrowLeftRight" Size="14"/>
                                    </Button>

                                    <Button Classes="icon-button"
                                            Command="{Binding RefreshCommand}"
                                            ToolTip.Tip="Refresh workspace">
                                        <LucideIcon Kind="RefreshCw" Size="14"/>
                                    </Button>

                                    <Button Classes="danger-subtle small"
                                            Command="{Binding DisconnectConnectionCommand}"
                                            ToolTip.Tip="Disconnect workspace"
                                            Padding="8">
                                        <LucideIcon Kind="PlugZap" Size="14"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Classes="card"
                                IsVisible="{Binding ShowNamespaceSelectionPrompt}">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource SurfaceBrand}">
                                        <LucideIcon Kind="Server"
                                                    Size="18"
                                                    Foreground="{DynamicResource AccentBrand}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Choose a namespace" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="Pick the Azure workspace you want to browse."
                                                   Classes="caption"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button Classes="primary"
                                        Command="{Binding OpenNamespacePanelCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="Server" Size="16"/>
                                        <TextBlock Text="Select Namespace" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Button Classes="secondary"
                                Command="{Binding LogoutCommand}"
                                IsVisible="{Binding Connection.IsAuthenticated}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <LucideIcon Kind="LogOut" Size="16"/>
                                <TextBlock Text="Sign Out"/>
                            </StackPanel>
                        </Button>

                        <Border Classes="empty-state">
                            <Border.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="!Connection.ShowAzureSections"/>
                                    <Binding Path="!HasActiveConnectionTab"/>
                                </MultiBinding>
                            </Border.IsVisible>
                            <StackPanel Spacing="14">
                                <StackPanel HorizontalAlignment="Center" Spacing="8">
                                    <LucideIcon Kind="Rocket" Size="28"
                                                HorizontalAlignment="Center"
                                                Foreground="{DynamicResource AccentBrand}"/>
                                    <TextBlock Text="Start a workspace"
                                               FontWeight="SemiBold"
                                               FontSize="16"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Open a saved connection or sign in to Azure to start browsing queues and topics."
                                               Classes="caption"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Button Classes="secondary"
                                        Command="{Binding LoginCommand}"
                                        IsVisible="{Binding !Connection.IsAuthenticated}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <LucideIcon Kind="Cloud" Size="16"/>
                                        <TextBlock Text="Sign in with Azure"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Quick switch" Classes="sidebar-section-label"/>
                            <Border Grid.Column="1"
                                    Classes="badge-muted"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding Connection.HasFavoriteConnections}">
                                <TextBlock Text="{Binding Connection.FavoriteConnections.Count}"/>
                            </Border>
                        </Grid>

                        <Button Classes="secondary"
                                Command="{Binding OpenConnectionLibraryCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Border Grid.Column="0"
                                        Width="32"
                                        Height="32"
                                        CornerRadius="8"
                                        Background="{DynamicResource SurfaceBrand}">
                                    <LucideIcon Kind="Library"
                                                Size="14"
                                                Foreground="{DynamicResource AccentBrand}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="My Connections" FontWeight="SemiBold"/>
                                    <TextBlock Text="Manage saved and recent connections"
                                               Classes="caption"
                                               FontSize="11"/>
                                </StackPanel>
                                <LucideIcon Grid.Column="2"
                                            Kind="ChevronRight"
                                            Size="14"
                                            Foreground="{DynamicResource SubtleForeground}"
                                            VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <ListBox ItemsSource="{Binding Connection.FavoriteConnections}"
                                 Classes="entity-list quick-switch-list"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 IsVisible="{Binding Connection.HasFavoriteConnections}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:SavedConnection">
                                    <Button Classes="subtle sidebar-quick-switch-button"
                                            Command="{Binding $parent[Window].DataContext.ConnectToSavedConnectionCommand}"
                                            CommandParameter="{Binding}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="0"
                                            Margin="0">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <Border Grid.Column="0"
                                                    Classes="selection-indicator"
                                                    VerticalAlignment="Stretch"
                                                    Margin="0,6,0,6">
                                                <Border.IsVisible>
                                                    <MultiBinding Converter="{StaticResource EntitySelectionConverter}">
                                                        <Binding Path="."/>
                                                        <Binding Path="$parent[Window].DataContext.ActiveTab.SavedConnection"/>
                                                    </MultiBinding>
                                                </Border.IsVisible>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Classes="sidebar-quick-switch-item">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                    <Border Grid.Column="0"
                                                            Width="30"
                                                            Height="30"
                                                            CornerRadius="8"
                                                            Background="{DynamicResource SurfaceBrand}">
                                                        <LucideIcon Kind="Cable"
                                                                    Size="13"
                                                                    Foreground="{DynamicResource AccentBrand}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding TypeDisplayName}"
                                                                       Classes="caption"
                                                                       FontSize="11"/>
                                                            <TextBlock Text="·"
                                                                       Classes="caption"
                                                                       FontSize="11"
                                                                       IsVisible="{Binding EntityName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                            <TextBlock Text="{Binding EntityName}"
                                                                       Classes="caption"
                                                                       FontSize="11"
                                                                       MaxWidth="120"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       IsVisible="{Binding EntityName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Border Grid.Column="2"
                                                            Classes="badge-env"
                                                            VerticalAlignment="Center"
                                                            IsVisible="{Binding HasEnvironment}">
                                                        <TextBlock Text="{Binding EnvironmentDisplayName}"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Classes="sidebar-hint-card"
                                IsVisible="{Binding !Connection.HasFavoriteConnections}">
                            <TextBlock Text="Favorite connections will appear here for one-click switching."
                                       Classes="caption"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Classes="sidebar-utility-dock">
                <StackPanel Margin="12,10,12,12" Spacing="4">
                    <TextBlock Text="Utilities" Classes="sidebar-section-label" Margin="0,0,0,4"/>

                    <Button Classes="subtle sidebar-utility-button"
                            Command="{Binding OpenLiveStreamCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <LucideIcon Kind="Radio" Size="16"/>
                            <TextBlock Text="Live Stream" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="subtle sidebar-utility-button"
                            Command="{Binding OpenChartsCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <LucideIcon Kind="ChartBar" Size="16"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="subtle sidebar-utility-button"
                            Command="{Binding OpenAlertsCommand}"
                            HorizontalAlignment="Stretch">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                <LucideIcon Kind="Bell" Size="16"/>
                                <TextBlock Text="Alerts" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="2"
                                    Background="{DynamicResource DangerBackground}"
                                    CornerRadius="10"
                                    Padding="8,2"
                                    IsVisible="{Binding FeaturePanels.ActiveAlertCount}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding FeaturePanels.ActiveAlertCount}"
                                           FontSize="11"
                                           Foreground="White"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button Classes="subtle sidebar-utility-button"
                            Command="{Binding OpenSettingsCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <LucideIcon Kind="Settings" Size="16"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
