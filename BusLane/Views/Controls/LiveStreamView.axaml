<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:BusLane.Models"
             x:Class="BusLane.Views.Controls.LiveStreamView"
             x:CompileBindings="False">

    <Border Classes="pane-card" Padding="0">
        <Grid RowDefinitions="Auto,Auto,*">
            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceSubtle}"
                    BorderBrush="{DynamicResource BorderMuted}"
                    BorderThickness="0,0,0,1"
                    Padding="20,16">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Classes="metric-icon-surface">
                                <LucideIcon Kind="Radio" Size="16"
                                            Foreground="{DynamicResource AccentBrand}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Live Stream" Classes="heading" VerticalAlignment="Center"/>

                            <!-- Status indicator - Fluent 2 compliant -->
                            <Border CornerRadius="4" Padding="8,4"
                                    Background="{Binding IsStreaming, Converter={StaticResource BoolToColorConverter}}"
                                    BorderThickness="1"
                                    BorderBrush="{Binding IsStreaming, Converter={StaticResource BoolToStatusColorConverter}}"
                                    ToolTip.Tip="Peek-based monitoring: the entity is polled about once per second, so messages consumed by other receivers between polls may not appear. Timestamps show when each message was enqueued.">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding IsStreaming, Converter={StaticResource BoolToStatusColorConverter}}"/>
                                    <TextBlock Text="{Binding IsStreaming, Converter={StaticResource BoolToStatusTextConverter}}"
                                               FontSize="12" 
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding IsStreaming, Converter={StaticResource BoolToStatusColorConverter}}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Current entity info -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding CurrentEntityName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding CurrentEntityType}" Classes="caption" Foreground="{DynamicResource SubtleForeground}"/>
                            <TextBlock Text=":" Classes="caption" Foreground="{DynamicResource SubtleForeground}"/>
                            <TextBlock Text="{Binding CurrentEntityName}" Classes="caption" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding MessageCount, StringFormat='{}({0} messages)'}"
                                   VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource SubtleForeground}"/>
                        <Button Classes="subtle small"
                                Command="{Binding ClearMessagesCommand}"
                                Padding="8,8">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <LucideIcon Kind="Eraser" Size="12"/>
                                <TextBlock Text="Clear"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="danger-subtle small"
                                Command="{Binding StopStreamCommand}"
                                IsVisible="{Binding IsStreaming}"
                                Padding="8,8">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <LucideIcon Kind="Square" Size="12"/>
                                <TextBlock Text="Stop"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Filter & Options Bar -->
            <Border Grid.Row="1"
                    Background="{DynamicResource LayerBackground}"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="0,0,0,1"
                    Padding="16,12">
                <Grid ColumnDefinitions="*,Auto">
                    <!-- Search/Filter -->
                    <Border Grid.Column="0" Background="{DynamicResource InputBackground}" CornerRadius="6" Padding="8,8" Margin="0,0,12,0"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderDefault}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <LucideIcon Grid.Column="0" Kind="Search"
                                      Size="14"
                                      Foreground="{DynamicResource MutedForeground}"
                                      Margin="4,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding FilterText, Mode=TwoWay}"
                                     PlaceholderText="Filter messages..."
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0,4"
                                     FontSize="13"/>
                            <Button Grid.Column="2"
                                    Classes="subtle small"
                                    Command="{Binding ClearFilterCommand}"
                                    IsVisible="{Binding FilterText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Padding="4">
                                <LucideIcon Kind="X" Size="12"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Options -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                        <CheckBox Content="Auto-scroll" IsChecked="{Binding AutoScroll}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Messages List -->
            <Grid Grid.Row="2">
                <!-- Loading/Connecting indicator - Fluent 2 compliant -->
                <Border IsVisible="{Binding IsConnecting}"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Classes="card-elevated"
                        Padding="32">
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="120" Height="4"/>
                        <TextBlock Text="Connecting to stream..." 
                                   Classes="body-strong"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Error message - Fluent 2 infobar style -->
                <Border IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        VerticalAlignment="Top" Margin="16"
                        Classes="infobar-error">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <LucideIcon Kind="TriangleAlert" Size="20" Foreground="{DynamicResource TextDanger}"/>
                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Foreground="{DynamicResource TextDanger}"
                                   VerticalAlignment="Center" 
                                   TextWrapping="Wrap"
                                   Classes="body"/>
                    </StackPanel>
                </Border>

                <!-- Not streaming state - Entity Selection -->
                <Grid IsVisible="{Binding ShowEntitySelector}"
                      RowDefinitions="Auto,*,Auto"
                      MaxWidth="640"
                      Margin="24,20">

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Spacing="8" Margin="0,4,0,16">
                        <Border Background="{DynamicResource SurfaceBrand}"
                                CornerRadius="12"
                                Padding="14"
                                HorizontalAlignment="Center">
                            <LucideIcon Kind="Radio" Size="28"
                                      Foreground="{DynamicResource AccentBrand}"/>
                        </Border>
                        <TextBlock Text="Select an entity to stream"
                                   Classes="heading"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Choose a queue or topic subscription to start receiving live messages"
                                   Classes="subtitle"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>

                    <!-- Entity selector -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsVisible="{Binding HasEntities}">
                        <StackPanel Spacing="16" Margin="0,0,4,0">
                            <!-- Queues section -->
                            <StackPanel Spacing="8" IsVisible="{Binding AvailableQueues.Count}">
                                <TextBlock Text="Queues" Classes="field-group-header"/>
                                <ListBox ItemsSource="{Binding AvailableQueues}"
                                         SelectedItem="{Binding SelectedStreamEntity}"
                                         Background="{DynamicResource CardBackground}"
                                         BorderBrush="{DynamicResource BorderDefault}"
                                         BorderThickness="1"
                                         CornerRadius="6"
                                         Padding="4">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="models:QueueInfo">
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="4">
                                                <Border Classes="entity-icon-queue" VerticalAlignment="Center">
                                                    <TextBlock Text="Q"/>
                                                </Border>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                                                <Border Classes="counter-active" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ActiveMessageCount, StringFormat='{}{0}'}"/>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <!-- Topics section -->
                            <StackPanel Spacing="8" IsVisible="{Binding AvailableTopics.Count}">
                                <TextBlock Text="Topics &amp; Subscriptions" Classes="field-group-header"/>
                                <ItemsControl ItemsSource="{Binding AvailableTopics}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="models:TopicInfo">
                                            <StackPanel Spacing="4" Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border Classes="entity-icon-topic" VerticalAlignment="Center">
                                                        <TextBlock Text="T"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                                </StackPanel>
                                                <ListBox ItemsSource="{Binding Subscriptions}"
                                                         SelectedItem="{Binding $parent[UserControl].DataContext.SelectedStreamEntity}"
                                                         Background="{DynamicResource CardBackground}"
                                                         BorderBrush="{DynamicResource BorderDefault}"
                                                         BorderThickness="1"
                                                         CornerRadius="6"
                                                         Margin="24,4,0,0"
                                                         Padding="4"
                                                         IsVisible="{Binding Subscriptions.Count}">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate DataType="models:SubscriptionInfo">
                                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="4">
                                                                <Border Classes="entity-icon-subscription" VerticalAlignment="Center">
                                                                    <TextBlock Text="S"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                                                                <Border Classes="counter-active" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding ActiveMessageCount, StringFormat='{}{0}'}"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                                <Border Classes="infobar" Margin="24,0,0,0" IsVisible="{Binding !Subscriptions.Count}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <LucideIcon Kind="Bell" Size="14" Foreground="{DynamicResource AccentBrand}"/>
                                                        <TextBlock Text="{Binding DisplayStatus}"
                                                                   FontSize="11" Foreground="{DynamicResource SubtleForeground}"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- No entities available -->
                    <Border Grid.Row="1"
                            Classes="infobar-error"
                            IsVisible="{Binding !HasEntities}"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <LucideIcon Kind="TriangleAlert" Size="16" Foreground="{DynamicResource TextDanger}"/>
                            <TextBlock Text="No queues or topics available. Please connect to a namespace first."
                                       Classes="body"
                                       Foreground="{DynamicResource TextDanger}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Start streaming button -->
                    <Button Grid.Row="2"
                            Classes="primary"
                            Content="Start Streaming"
                            Command="{Binding StartStreamForSelectedEntityCommand}"
                            HorizontalAlignment="Center"
                            Padding="24,10"
                            Margin="0,16,0,0"
                            IsVisible="{Binding HasEntities}"
                            IsEnabled="{Binding SelectedStreamEntity, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                </Grid>

                <!-- Messages list - Fluent 2 compliant -->
                <ListBox ItemsSource="{Binding FilteredMessages}"
                         SelectedItem="{Binding SelectedMessage}"
                         IsVisible="{Binding IsStreaming}"
                         Padding="8"
                         Classes="entity-list">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:LiveStreamMessage">
                            <Border Classes="entity-item" Padding="12">
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                    <!-- Message ID and time -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding MessageId}" Classes="body-strong"/>
                                        <Border Classes="badge-info" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding EntityType}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding EnqueuedAt, StringFormat='{}{0:HH:mm:ss.fff}'}"
                                               Classes="caption"/>

                                    <!-- Body preview -->
                                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                               Text="{Binding BodyPreview}"
                                               MaxLines="2" TextTrimming="CharacterEllipsis"
                                               Classes="body"
                                               Foreground="{DynamicResource SubtleForeground}"
                                               Margin="0,6,0,0"/>

                                    <!-- Metadata -->
                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                                        <TextBlock Classes="caption" Foreground="{DynamicResource MutedForeground}">
                                            <Run Text="Seq:"/>
                                            <Run Text="{Binding SequenceNumber}"/>
                                        </TextBlock>
                                        <TextBlock Classes="caption" Foreground="{DynamicResource MutedForeground}"
                                                   IsVisible="{Binding CorrelationId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <Run Text="Correlation:"/>
                                            <Run Text="{Binding CorrelationId}"/>
                                        </TextBlock>
                                        <TextBlock Classes="caption" Foreground="{DynamicResource MutedForeground}"
                                                   IsVisible="{Binding SessionId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <Run Text="Session:"/>
                                            <Run Text="{Binding SessionId}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Border>
</UserControl>
