<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BusLane.ViewModels.Dashboard"
             xmlns:local="using:BusLane.Views.Controls"
             xmlns:dialogs="using:BusLane.Views.Dialogs"
             x:Class="BusLane.Views.Controls.DashboardView"
             x:DataType="vm:DashboardViewModel"
             x:CompileBindings="False">

    <Grid>
        <Border Classes="card" Padding="0">
            <Grid RowDefinitions="Auto,*">
                <!-- Header -->
                <Border Grid.Row="0"
                        Background="{DynamicResource LayerBackground}"
                        BorderBrush="{DynamicResource BorderMuted}"
                        BorderThickness="0,0,0,1"
                        Padding="20,16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" Classes="metric-icon-surface" Margin="0,0,12,0">
                            <LucideIcon Kind="LayoutDashboard" Size="16"
                                        Foreground="{DynamicResource AccentBrand}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Dashboard" Classes="heading"/>
                            <TextBlock Text="Custom widget layout for monitoring metrics"
                                       Classes="caption"/>
                        </StackPanel>

                        <Button Grid.Column="2" Classes="primary small"
                                Command="{Binding OpenAddWidgetDialogCommand}"
                                IsEnabled="{Binding CanAddWidget}"
                                Padding="12,8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <LucideIcon Kind="Plus" Size="14"/>
                                <TextBlock Text="Add Widget"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Dashboard Content -->
                <ScrollViewer x:Name="WidgetScrollViewer" Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Widgets}" Margin="16">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:DashboardWidgetViewModel">
                                <Border Classes="card"
                                        Padding="0"
                                        Height="{Binding Height, Converter={StaticResource GridRowToHeightConverter}}"
                                        Margin="0,0,8,8">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource GridColumnToWidthConverter}">
                                            <Binding Path="Width"/>
                                            <Binding Path="Bounds.Width" ElementName="WidgetScrollViewer"/>
                                        </MultiBinding>
                                    </Border.Width>
                                    <Grid RowDefinitions="Auto,*">
                                        <!-- Widget Header -->
                                        <Border Grid.Row="0" Padding="12,8" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"/>
                                                <Button Grid.Column="1" Classes="subtle small"
                                                        Command="{Binding $parent[ItemsControl].((vm:DashboardViewModel)DataContext).RemoveWidgetCommand}"
                                                        CommandParameter="{Binding}"
                                                        Padding="4">
                                                    <LucideIcon Kind="X" Size="14"/>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <!-- Widget Content -->
                                        <ContentControl Grid.Row="1" Content="{Binding}">
                                            <ContentControl.ContentTemplate>
                                                <local:DashboardWidgetTemplateSelector>
                                                    <local:DashboardWidgetTemplateSelector.LineChartTemplate>
                                                        <DataTemplate DataType="vm:LineChartWidgetViewModel">
                                                            <Border Margin="8"
                                                                    Classes="message-empty-state">
                                                                <StackPanel HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Spacing="8">
                                                                    <LucideIcon Kind="ChartSpline" Size="28"
                                                                                Foreground="{DynamicResource SubtleForeground}"
                                                                                HorizontalAlignment="Center"
                                                                                Opacity="0.5"/>
                                                                    <TextBlock Text="Chart unavailable in this build"
                                                                               Classes="caption"
                                                                               HorizontalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </local:DashboardWidgetTemplateSelector.LineChartTemplate>
                                                    <local:DashboardWidgetTemplateSelector.PieChartTemplate>
                                                        <DataTemplate DataType="vm:PieChartWidgetViewModel">
                                                            <Border Margin="8"
                                                                    Classes="message-empty-state">
                                                                <StackPanel HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Spacing="8">
                                                                    <LucideIcon Kind="FileChartPie" Size="28"
                                                                                Foreground="{DynamicResource SubtleForeground}"
                                                                                HorizontalAlignment="Center"
                                                                                Opacity="0.5"/>
                                                                    <TextBlock Text="Chart unavailable in this build"
                                                                               Classes="caption"
                                                                               HorizontalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </local:DashboardWidgetTemplateSelector.PieChartTemplate>
                                                    <local:DashboardWidgetTemplateSelector.BarChartTemplate>
                                                        <DataTemplate DataType="vm:BarChartWidgetViewModel">
                                                            <Border Margin="8"
                                                                    Classes="message-empty-state">
                                                                <StackPanel HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Spacing="8">
                                                                    <LucideIcon Kind="ChartColumnBig" Size="28"
                                                                                Foreground="{DynamicResource SubtleForeground}"
                                                                                HorizontalAlignment="Center"
                                                                                Opacity="0.5"/>
                                                                    <TextBlock Text="Chart unavailable in this build"
                                                                               Classes="caption"
                                                                               HorizontalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </local:DashboardWidgetTemplateSelector.BarChartTemplate>
                                                    <local:DashboardWidgetTemplateSelector.MetricCardTemplate>
                                                        <DataTemplate DataType="vm:MetricCardWidgetViewModel">
                                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                                                <TextBlock Text="{Binding CurrentValue, StringFormat='{}{0:N0}'}"
                                                                           FontSize="36" FontWeight="Bold"
                                                                           HorizontalAlignment="Center" />
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                                                    <LucideIcon Kind="TrendingUp" Size="16"
                                                                                IsVisible="{Binding IsTrendUp}" />
                                                                    <LucideIcon Kind="TrendingDown" Size="16"
                                                                                IsVisible="{Binding !IsTrendUp}" />
                                                                    <TextBlock Text="{Binding TrendPercentage}"
                                                                               FontSize="14" FontWeight="SemiBold" />
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding MetricUnit}"
                                                                           FontSize="12" Opacity="0.6"
                                                                           HorizontalAlignment="Center" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </local:DashboardWidgetTemplateSelector.MetricCardTemplate>
                                                </local:DashboardWidgetTemplateSelector>
                                            </ContentControl.ContentTemplate>
                                        </ContentControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Add Widget Dialog Overlay -->
        <Border IsVisible="{Binding IsAddWidgetDialogOpen}"
                Background="{DynamicResource ModalOverlay}"
                IsHitTestVisible="True">
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="12"
                    MaxWidth="500"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BoxShadow="0 8 24 0 #32000000">
                <dialogs:AddWidgetDialog />
            </Border>
        </Border>
    </Grid>
</UserControl>
