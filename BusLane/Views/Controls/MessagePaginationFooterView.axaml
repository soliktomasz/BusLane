<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="using:BusLane.ViewModels.Core"
             x:Class="BusLane.Views.Controls.MessagePaginationFooterView"
             x:DataType="core:MessageOperationsViewModel"
             x:CompileBindings="False">

    <UserControl.Styles>
        <Style Selector="Border.pager-surface">
            <Setter Property="Background" Value="{DynamicResource LayerBackground}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMuted}"/>
        </Style>

        <Style Selector="Border.pager-badge">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrand}"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrand}"/>
        </Style>

        <Style Selector="Border.pager-badge TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrand}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Border.pager-actions">
            <Setter Property="Background" Value="{DynamicResource SurfaceSubtle}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMuted}"/>
        </Style>

        <Style Selector="Button.pager-nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
    </UserControl.Styles>

    <Border Classes="pager-surface"
            IsVisible="{Binding Pagination.HasPageInfo}">
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="16">
            <Border Grid.Column="0"
                    Classes="pager-badge"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding Pagination.PageLabel}"/>
            </Border>

            <StackPanel Grid.Column="1"
                        Spacing="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="{Binding Pagination.PageRangeText}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <TextBlock Text="{Binding Pagination.PageDetailText}"
                           Classes="caption"
                           Foreground="{DynamicResource SubtleForeground}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           IsVisible="{Binding Pagination.PageDetailText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            </StackPanel>

            <Border Grid.Column="2"
                    Classes="pager-actions"
                    VerticalAlignment="Center">
                <Grid ColumnDefinitions="Auto,Auto,Auto">
                    <Button Grid.Column="0"
                            Classes="subtle small pager-nav"
                            Command="{Binding LoadPreviousPageCommand}"
                            IsEnabled="{Binding Pagination.CanGoPrevious}"
                            ToolTip.Tip="Previous page">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <LucideIcon Kind="ChevronLeft" Size="14"/>
                            <TextBlock Text="Previous"/>
                        </StackPanel>
                    </Button>

                    <Border Grid.Column="1"
                            Width="1"
                            Margin="0,8"
                            Background="{DynamicResource BorderDefault}"/>

                    <Button Grid.Column="2"
                            Classes="subtle small pager-nav"
                            Command="{Binding LoadNextPageCommand}"
                            IsEnabled="{Binding Pagination.CanGoNext}"
                            ToolTip.Tip="Next page">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Next"/>
                            <LucideIcon Kind="ChevronRight" Size="14"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
