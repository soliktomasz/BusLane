<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BusLane.ViewModels"
        xmlns:controls="using:BusLane.Views.Controls"
        xmlns:dialogs="using:BusLane.Views.Dialogs"
        x:Class="BusLane.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        x:Name="MainWindowControl"
        Title="BusLane - Service Bus Manager"
        Icon="/Assets/icon.png"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen">
    <Grid ColumnDefinitions="Auto,*">
        <!-- Navigation Pane (Fluent 2 Sidebar) -->
        <controls:NavigationSidebar Grid.Column="0"
                                    IsVisible="{Binding IsNavigationPanelVisible}"/>

        <!-- Main Content -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- Tab Bar with Show Panel Button -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                <!-- Show Panel Button (visible when panel is hidden and tabs exist) -->
                <Border Grid.Column="0"
                        Background="{DynamicResource TabNavBackground}"
                        BorderBrush="{DynamicResource BorderDefault}"
                        BorderThickness="0,0,0,1"
                        Padding="12,8"
                        IsVisible="{Binding !IsNavigationPanelVisible}">
                    <Button Classes="subtle icon-button"
                            Command="{Binding ToggleNavigationPanelCommand}"
                            ToolTip.Tip="Show navigation panel"
                            Padding="6">
                        <LucideIcon Kind="PanelLeftOpen" Size="16"/>
                    </Button>
                </Border>
                
                <controls:TabBarView Grid.Column="1"/>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="24" x:Name="MainContentGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="0"/>
                </Grid.RowDefinitions>

                <!-- Welcome / Not Connected -->
                <controls:WelcomeView Grid.Row="1"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>

            <!-- Content when namespace selected (Azure mode) -->
                <Grid Grid.Row="0" Grid.RowSpan="2"
                  IsVisible="{Binding IsActiveTabAzureMode}"
                  RowDefinitions="Auto,*">

                <!-- Header -->
                <Border Grid.Row="0" Classes="page-header-surface" Margin="0,0,0,16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding ActiveTab.Namespace.Name}" Classes="title"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Resource group" Classes="caption"/>
                                <TextBlock Text="{Binding ActiveTab.Namespace.ResourceGroup}" Classes="caption"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="secondary small"
                                Command="{Binding RefreshCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <LucideIcon Kind="RefreshCw" Size="12"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Main content grid -->
                <Grid x:Name="AzureWorkspaceGrid"
                      Grid.Row="1"
                      ColumnDefinitions="0,1.2*,1.8*">
                    <Button Grid.Column="0"
                            Classes="entity-pane-restore-handle"
                            Command="{Binding ShowEntityPaneCommand}"
                            IsVisible="{Binding !IsCurrentEntityPaneVisible}"
                            ToolTip.Tip="Show entity pane">
                        <LucideIcon Kind="PanelLeftOpen" Size="14"/>
                    </Button>

                    <!-- Service Bus Tree View -->
                    <controls:AzureEntityTreeView Grid.Column="1"
                                                  Margin="0,0,12,0"
                                                  IsVisible="{Binding IsCurrentEntityPaneVisible}"/>

                    <!-- Messages Panel -->
                    <controls:MessagesPanelView Grid.Column="2" Margin="12,0,0,0"/>
                </Grid>
            </Grid>

            <!-- Content when connected via connection string -->
            <Grid Grid.Row="0" Grid.RowSpan="2"
                  IsVisible="{Binding IsActiveTabConnectionStringMode}"
                  RowDefinitions="Auto,*">

                <!-- Header -->
                <Border Grid.Row="0" Classes="page-header-surface" Margin="0,0,0,16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding ActiveTab.SavedConnection.Name}" Classes="title"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{Binding ActiveTab.SavedConnection.TypeDisplayName}" Classes="caption"/>
                                <TextBlock Text="{Binding ActiveTab.SavedConnection.EntityName}"
                                           Classes="caption"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding ActiveTab.SavedConnection.EntityName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <TextBlock Text="{Binding ActiveTab.SavedConnection.Endpoint}"
                                           Classes="caption"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding ActiveTab.SavedConnection.IsNamespaceLevel}"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="secondary small"
                                Command="{Binding RefreshConnectionCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <LucideIcon Kind="RefreshCw" Size="12"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Main content for connection string mode -->
                <Grid x:Name="ConnectionWorkspaceGrid"
                      Grid.Row="1"
                      ColumnDefinitions="0,1.2*,1.8*">
                    <Button Grid.Column="0"
                            Classes="entity-pane-restore-handle"
                            Command="{Binding ShowEntityPaneCommand}"
                            IsVisible="{Binding !IsCurrentEntityPaneVisible}"
                            ToolTip.Tip="Show entity pane">
                        <LucideIcon Kind="PanelLeftOpen" Size="14"/>
                    </Button>

                    <!-- Entity Tree for connection string mode -->
                    <controls:EntityTreeView Grid.Column="1"
                                             Margin="0,0,12,0"
                                             IsVisible="{Binding IsCurrentEntityPaneVisible}"/>

                    <!-- Messages Panel (reusing same structure as Azure mode) -->
                    <controls:MessagesPanelView Grid.Column="2" Margin="12,0,0,0"/>
                </Grid>
            </Grid>

            <!-- Live Stream Panel (overlay when active) -->
            <Border Grid.Row="0" Grid.RowSpan="2"
                    IsVisible="{Binding FeaturePanels.ShowLiveStream}"
                    Background="{DynamicResource AppBackground}">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Classes="page-header-surface" Margin="0,0,0,16">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" Classes="metric-icon-surface" Margin="0,0,12,0">
                                <LucideIcon Kind="Radio" Size="18"
                                            Foreground="{DynamicResource AccentBrand}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Live Message Stream" Classes="heading"/>
                                <TextBlock Text="Real-time message monitoring for queues and subscriptions"
                                           Classes="caption"/>
                            </StackPanel>
                            <Button Grid.Column="2" Classes="secondary small"
                                    Command="{Binding CloseLiveStreamCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <LucideIcon Kind="X" Size="14"/>
                                    <TextBlock Text="Close"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                    <controls:LiveStreamView Grid.Row="1" DataContext="{Binding FeaturePanels.LiveStreamViewModel}"/>
                </Grid>
            </Border>

            <!-- Charts Panel (overlay when active) -->
            <Border Grid.Row="0" Grid.RowSpan="2"
                    IsVisible="{Binding FeaturePanels.ShowCharts}"
                    Background="{DynamicResource AppBackground}">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Classes="page-header-surface" Margin="0,0,0,16">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" Classes="metric-icon-surface" Margin="0,0,12,0">
                                <LucideIcon Kind="LayoutDashboard" Size="18"
                                            Foreground="{DynamicResource AccentBrand}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Dashboard" Classes="heading"/>
                                <TextBlock Text="Namespace metrics, inbox, and entity summaries"
                                           Classes="caption"/>
                            </StackPanel>
                            <Button Grid.Column="2" Classes="secondary small"
                                    Command="{Binding CloseChartsCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <LucideIcon Kind="X" Size="14"/>
                                    <TextBlock Text="Close"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                    <controls:NamespaceDashboardView Grid.Row="1" DataContext="{Binding NamespaceDashboard}"/>
                </Grid>
            </Border>

            <!-- Tab Loading Overlay (shown when connecting to a namespace) -->
            <Border Grid.Row="0" Grid.RowSpan="2"
                    IsVisible="{Binding ActiveTab.IsLoading, FallbackValue=False}"
                    Background="{DynamicResource LoadingOverlay}"
                    IsHitTestVisible="True">
                <Border Background="{DynamicResource CardBackground}"
                        Padding="48,40"
                        CornerRadius="16"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource BorderDefault}"
                        BoxShadow="0 12 48 0 #50000000"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MinWidth="360">
                    <StackPanel Spacing="24" HorizontalAlignment="Center">
                        <!-- Animated loading ring -->
                        <Border Width="64" Height="64"
                                HorizontalAlignment="Center"
                                CornerRadius="32"
                                BorderThickness="4"
                                BorderBrush="{DynamicResource AccentBrand}"
                                Background="Transparent">
                            <Border.Styles>
                                <Style Selector="Border">
                                    <Style.Animations>
                                        <Animation Duration="0:0:1.2" IterationCount="INFINITE">
                                            <KeyFrame Cue="0%">
                                                <Setter Property="Opacity" Value="0.3"/>
                                            </KeyFrame>
                                            <KeyFrame Cue="50%">
                                                <Setter Property="Opacity" Value="1"/>
                                            </KeyFrame>
                                            <KeyFrame Cue="100%">
                                                <Setter Property="Opacity" Value="0.3"/>
                                            </KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                            </Border.Styles>
                        </Border>
                        
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="Connecting..."
                                       Classes="title-small"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ActiveTab.StatusMessage}"
                                       FontSize="16"
                                       Foreground="{DynamicResource SubtleForeground}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="300"/>
                        </StackPanel>
                        
                        <ProgressBar IsIndeterminate="True" 
                                     Width="240" 
                                     Height="4"
                                     Foreground="{DynamicResource AccentBrand}"
                                     Background="{DynamicResource BorderDefault}"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Status Bar -->
            <Border Grid.Row="2" Margin="0,12,0,0">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                    <ProgressBar Grid.Column="0"
                                 IsIndeterminate="True"
                                 IsVisible="{Binding IsLoading}"
                                 Width="100" Height="3"
                                 VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Classes="subtle"
                            Command="{Binding ToggleStatusPopupCommand}"
                            HorizontalAlignment="Left"
                            Margin="12,0,0,0"
                            Padding="8,4"
                            Cursor="Hand"
                            ToolTip.Tip="Click to see full message">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Classes="caption"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="400"/>
                    </Button>

                    <controls:UpdateNotificationView Grid.Column="2"
                                                     DataContext="{Binding UpdateNotification}"
                                                     VerticalAlignment="Center"/>

                    <!-- Terminal Toggle Button -->
                    <ToggleButton Grid.Column="3"
                                  Classes="subtle icon-button"
                                  IsChecked="{Binding Terminal.ShowTerminalPanel}"
                                  Padding="6"
                                  Margin="8,0,0,0"
                                  ToolTip.Tip="Toggle terminal">
                        <LucideIcon Kind="Terminal" Size="14"/>
                    </ToggleButton>

                    <!-- Log Viewer Toggle Button -->
                    <ToggleButton Grid.Column="4"
                                  Classes="subtle icon-button"
                                  IsChecked="{Binding LogViewer.IsOpen}"
                                  Padding="6"
                                  Margin="8,0,0,0"
                                  ToolTip.Tip="Toggle activity log">
                        <Grid>
                            <LucideIcon Kind="ScrollText" Size="14"/>
                            <Border Width="8"
                                    Height="8"
                                    CornerRadius="4"
                                    Background="{DynamicResource TextDanger}"
                                    BorderBrush="{DynamicResource CardBackground}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,-1,-1,0"
                                    IsVisible="{Binding LogViewer.HasUnreadErrors}"/>
                        </Grid>
                    </ToggleButton>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="3"
                          Height="2"
                          ResizeDirection="Rows"
                          VerticalAlignment="Top"
                          Margin="0,-1,0,0"
                          Background="{DynamicResource BorderDefault}"
                          ShowsPreview="False"
                          PointerReleased="OnTerminalGridSplitterPointerReleased"
                          IsVisible="{Binding Terminal.IsDockedVisible}"/>

            <controls:TerminalPanel Grid.Row="3"
                                    Margin="0,0,0,0"
                                    VerticalAlignment="Stretch"
                                    HorizontalAlignment="Stretch"
                                    DataContext="{Binding Terminal}"
                                    IsVisible="{Binding IsDockedVisible}"/>
            </Grid>
        </Grid>

        <!-- Modal Dialogs -->
        <dialogs:StatusPopupDialog Grid.Column="0" Grid.ColumnSpan="2"/>
        <dialogs:MessageDetailDialog Grid.Column="0" Grid.ColumnSpan="2"/>
        <dialogs:SendMessageDialog Grid.Column="0" Grid.ColumnSpan="2"/>
        <dialogs:SaveMessageDialog Grid.Column="0" Grid.ColumnSpan="2"/>
        <dialogs:LoadMessageDialog Grid.Column="0" Grid.ColumnSpan="2"/>
        <dialogs:ConnectionLibraryDialog Grid.Column="0" Grid.ColumnSpan="2"/>
        <dialogs:SettingsDialog Grid.Column="0" Grid.ColumnSpan="2"/>
        <dialogs:ConfirmDialog Grid.Column="0" Grid.ColumnSpan="2"/>
        <dialogs:KeyboardShortcutsDialog Grid.Column="0" Grid.ColumnSpan="2"/>
        <dialogs:DeviceCodeDialog Grid.Column="0" Grid.ColumnSpan="2"/>

        <!-- Namespace Selection Slide-in Panel (Azure mode) -->
        <controls:NamespaceSelectionPanel Grid.Column="0" Grid.ColumnSpan="2"
                                          DataContext="{Binding NamespaceSelection}"/>

        <!-- Alerts Dialog (modal overlay) -->
        <Border Grid.Column="0" Grid.ColumnSpan="2"
                IsVisible="{Binding FeaturePanels.ShowAlerts}"
                Background="{DynamicResource ModalOverlay}">
            <Border Background="{DynamicResource CardBackground}"
                    CornerRadius="12"
                    MaxWidth="900" MaxHeight="700"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BoxShadow="0 8 24 0 #32000000">
                <dialogs:AlertsDialog DataContext="{Binding FeaturePanels.AlertsViewModel}"/>
            </Border>
        </Border>

        <!-- Log Viewer Slide-out Panel -->
        <controls:LogViewerPanel Grid.Column="0" Grid.ColumnSpan="2"
                                 DataContext="{Binding LogViewer}"/>

        <!-- App Lock Overlay -->
        <Border Grid.Column="0" Grid.ColumnSpan="2"
                Classes="modal-overlay"
                IsVisible="{Binding AppLock.IsLocked}"
                IsHitTestVisible="True">
            <Border Classes="modal modal-small"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="0"
                    MinWidth="420">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource BorderDefault}"
                            BorderThickness="0,0,0,1"
                            Padding="24,20">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0"
                                    Width="44"
                                    Height="44"
                                    CornerRadius="12"
                                    Background="{DynamicResource SurfaceBrand}"
                                    Margin="0,0,16,0">
                                <LucideIcon Kind="Lock" Size="20"
                                            Foreground="{DynamicResource AccentBrand}"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="Unlock BusLane" Classes="title-small"/>
                                <TextBlock Text="BusLane is protected on launch. Saved-connection encryption remains unchanged."
                                           Classes="caption"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Padding="24">
                        <StackPanel Spacing="16">
                            <Border Classes="infobar-error"
                                    IsVisible="{Binding AppLock.ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding AppLock.ErrorMessage}"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <ProgressBar IsIndeterminate="True"
                                         Height="4"
                                         IsVisible="{Binding AppLock.IsUnlocking}"/>

                            <StackPanel Spacing="12"
                                        IsVisible="{Binding !AppLock.IsRecoveryMode}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Password" FontWeight="Medium" FontSize="13"/>
                                    <TextBox Text="{Binding AppLock.Password}"
                                             PasswordChar="●"
                                             PlaceholderText="Enter your app lock password"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="primary small"
                                            Content="Unlock"
                                            Command="{Binding AppLock.UnlockCommand}"
                                            IsEnabled="{Binding !AppLock.IsUnlocking}"/>
                                    <Button Classes="secondary small"
                                            Content="Use biometrics"
                                            Command="{Binding AppLock.UnlockWithBiometricsCommand}"
                                            IsVisible="{Binding AppLock.CanUseBiometrics}"
                                            IsEnabled="{Binding !AppLock.IsUnlocking}"/>
                                </StackPanel>

                                <Button Classes="subtle small"
                                        Content="Use recovery code instead"
                                        Command="{Binding AppLock.EnterRecoveryModeCommand}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>

                            <StackPanel Spacing="12"
                                        IsVisible="{Binding AppLock.IsRecoveryMode}">
                                <TextBlock Text="Use your recovery code to set a new password or disable app lock for future launches."
                                           Classes="caption"
                                           TextWrapping="Wrap"/>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Recovery code" FontWeight="Medium" FontSize="13"/>
                                    <TextBox Text="{Binding AppLock.RecoveryCode}"
                                             PlaceholderText="Enter your recovery code"/>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="New password" FontWeight="Medium" FontSize="13"/>
                                    <TextBox Text="{Binding AppLock.NewPassword}"
                                             PasswordChar="●"
                                             PlaceholderText="Set a new password"/>
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="Confirm new password" FontWeight="Medium" FontSize="13"/>
                                    <TextBox Text="{Binding AppLock.ConfirmNewPassword}"
                                             PasswordChar="●"
                                             PlaceholderText="Confirm the new password"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="primary small"
                                            Content="Reset Password And Unlock"
                                            Command="{Binding AppLock.RecoverWithNewPasswordCommand}"
                                            IsEnabled="{Binding !AppLock.IsUnlocking}"/>
                                    <Button Classes="danger-outline small"
                                            Content="Disable App Lock"
                                            Command="{Binding AppLock.DisableLockWithRecoveryCodeCommand}"
                                            IsEnabled="{Binding !AppLock.IsUnlocking}"/>
                                </StackPanel>

                                <Button Classes="subtle small"
                                        Content="Back to password"
                                        Command="{Binding AppLock.ExitRecoveryModeCommand}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
